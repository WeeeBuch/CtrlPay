<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CtrlPay.Avalonia"
             xmlns:conv="clr-namespace:CtrlPay.Avalonia.Converters"
             x:Class="CtrlPay.Avalonia.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <conv:BoolToFlowTableTextConverter x:Key="BoolToFlowTableTextConverter"/>
        <conv:TransactionTypeToColorConverter x:Key="TransactionTypeToColorConverter"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
        <conv:StatusToTextConverter x:Key="StatusToTextConverter"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://CtrlPay.Avalonia/Styles/Styles.axaml"/>
        <StyleInclude Source="avares://CtrlPay.Avalonia/Styles/StatusEllipse.axaml"/>
        <StyleInclude Source="avares://CtrlPay.Avalonia/Styles/StatusTextBlock.axaml"/>
        <StyleInclude Source="avares://CtrlPay.Avalonia/Styles/StatusBorder.axaml"/>
        <StyleInclude Source="avares://CtrlPay.Avalonia/Styles/StylePillList.axaml"/>
        <StyleInclude Source="avares://CtrlPay.Avalonia/Styles/StylesCustomer.axaml"/>
    </Application.Styles>

</Application>
