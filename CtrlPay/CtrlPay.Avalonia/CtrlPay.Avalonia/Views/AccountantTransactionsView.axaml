<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             xmlns:hc="using:CtrlPay.Avalonia.HelperClasses"
             xmlns:frontend="using:CtrlPay.Repos.Frontend"
             xmlns:repos="using:CtrlPay.Repos"
             x:DataType="vm:AccountantTransactionsViewModel"
             x:Class="CtrlPay.Avalonia.AccountantTransactionsView">

    <Design.DataContext>
        <vm:AccountantTransactionsViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource Color.Background}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Color.Border}" Padding="15">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <Button Command="{Binding ToggleViewCommand}" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource Icon.SwapHorizontal}" Width="16" Height="16"/>
                        <TextBlock Text="{Binding IsFlowView, Converter={StaticResource BoolToFlowTableTextConverter}}" />
                    </StackPanel>
                </Button>

                <Separator Width="1" Height="20" Background="{DynamicResource Color.Border}"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Customer:" VerticalAlignment="Center" Opacity="0.6"/>
                    <ComboBox ItemsSource="{Binding Customers}" 
                              SelectedItem="{Binding SelectedCustomer}" 
                              Width="180"/>
                </StackPanel>

                <TextBox Watermark="Search by Hash or Customer..." Width="300" Text="{Binding SearchTerm}"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <!-- Table View -->
            <Grid IsVisible="{Binding !IsFlowView}" RowDefinitions="Auto, *">
                <!-- Table Header -->
                <Border Grid.Row="0" Background="{DynamicResource Color.Surface}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Color.Border}" Padding="15,10">
                    <Grid ColumnDefinitions="50, 130, *, 200, 100, 200, 120">
                        <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" Opacity="0.5"/>
                        <TextBlock Grid.Column="1" Text="Date" FontWeight="Bold" Opacity="0.5"/>
                        <TextBlock Grid.Column="2" Text="Customer" FontWeight="Bold" Opacity="0.5"/>
                        <TextBlock Grid.Column="3" Text="TX Hash (XMR)" FontWeight="Bold" Opacity="0.5"/>
                        <TextBlock Grid.Column="4" Text="Type" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="Amount" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="Status" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Table Body -->
                <ListBox Grid.Row="1" ItemsSource="{Binding FilteredTransactions}" Background="Transparent">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="15,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Color.Border}"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="repos:AccountantTransactionDTO">
                            <Grid ColumnDefinitions="50, 130, *, 200, 100, 200, 120">
                                <TextBlock Grid.Column="0" Text="{Binding Id}" VerticalAlignment="Center" FontSize="12" Opacity="0.6"/>
                                <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:dd.MM.yy HH:mm}'}" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Grid.Column="2" Text="{Binding CustomerName}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Monero Hash: Shortened with Tooltip -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" ToolTip.Tip="{Binding Title}">
                                    <TextBlock Text="{Binding Title}" 
                                               FontSize="11" 
                                               FontFamily="Cascadia Code,Consolas,Monospace"
                                               Opacity="0.7" 
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Type}" 
                                               FontSize="12"
                                               Foreground="{Binding Type, Converter={StaticResource TransactionTypeToColorConverter}}" 
                                               />
                                </Border>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Amount, StringFormat='{}{0:F12}'}" 
                                               FontFamily="Cascadia Code,Consolas,Monospace"
                                               FontWeight="Bold"
                                               FontSize="13"/>
                                    <TextBlock Text=" XMR" FontSize="9" Opacity="0.4" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                </StackPanel>

                                <Border Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{Binding State, Converter={StaticResource StatusToBrushConverter}}"
                                        Padding="6,2" CornerRadius="4">
                                    <TextBlock Text="{Binding State}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Flow View -->
            <ScrollViewer IsVisible="{Binding IsFlowView}">
                <Grid ColumnDefinitions="*, 250, *" Margin="20">
                    <!-- INCOMING (LEFT) -->
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="Incoming (Credits)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10" Opacity="0.5" FontSize="12"/>
                        <ItemsControl ItemsSource="{Binding IncomingTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="repos:AccountantTransactionDTO">
                                    <Border Margin="4" Padding="12" CornerRadius="6" Background="{DynamicResource Color.Surface}" BorderThickness="1" BorderBrush="{DynamicResource Color.Border}">
                                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding CustomerName}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Amount, StringFormat='+ {0:F12}'}" Foreground="#4CAF50" FontWeight="Bold" FontSize="12" FontFamily="Monospace"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Title}" FontSize="9" Opacity="0.3" FontFamily="Monospace" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- CENTRAL HUB -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,50,0,0" HorizontalAlignment="Center" Spacing="0">
                        <Panel Width="140" Height="140">
                            <Ellipse Fill="{DynamicResource Color.Primary}" Opacity="0.05" Margin="-20"/>
                            <Ellipse Fill="{DynamicResource Color.Primary}" Opacity="0.1" Margin="-10"/>
                            <Ellipse Fill="{DynamicResource Color.Primary}"/>
                            <PathIcon Data="{StaticResource Icon.User}" Width="50" Height="50" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Panel>
                        <TextBlock Text="{Binding SelectedCustomer}" HorizontalAlignment="Center" Margin="0,20,0,5" FontWeight="Black" FontSize="20" TextAlignment="Center" TextWrapping="Wrap"/>
                        <Border Background="{DynamicResource Color.Surface}" Padding="10,4" CornerRadius="15" HorizontalAlignment="Center">
                             <TextBlock Text="TRANSACTION HUB" LetterSpacing="2" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                        </Border>
                    </StackPanel>

                    <!-- OUTGOING (RIGHT) -->
                    <StackPanel Grid.Column="2" Spacing="8">
                        <TextBlock Text="Outgoing (Debits)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10" Opacity="0.5" FontSize="12"/>
                        <ItemsControl ItemsSource="{Binding OutgoingTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="repos:AccountantTransactionDTO">
                                    <Border Margin="4" Padding="12" CornerRadius="6" Background="{DynamicResource Color.Surface}" BorderThickness="1" BorderBrush="{DynamicResource Color.Border}">
                                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Amount, StringFormat='- {0:F12}'}" Foreground="#F44336" FontWeight="Bold" FontSize="12" FontFamily="Monospace"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CustomerName}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Title}" FontSize="9" Opacity="0.3" FontFamily="Monospace" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
