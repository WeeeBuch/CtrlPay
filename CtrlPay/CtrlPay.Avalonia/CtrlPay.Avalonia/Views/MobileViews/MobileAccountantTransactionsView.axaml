<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             xmlns:repos="using:CtrlPay.Repos"
             x:DataType="vm:AccountantTransactionsViewModel"
             x:Class="CtrlPay.Avalonia.Views.MobileViews.MobileAccountantTransactionsView"
             Background="{DynamicResource Color.Background}">
  <UserControl.Styles>
    <Style Selector="Button.headerBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </UserControl.Styles>
  <ScrollViewer>
    <StackPanel Margin="12" Spacing="12">
      <TextBox Watermark="{DynamicResource Accountant.Transactions.Search}" MinHeight="44" Text="{Binding SearchTerm}"/>

      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="6" Grid.Column="0">
          <TextBlock Text="{DynamicResource Accountant.Transactions.Customer}" FontSize="12" Opacity="0.6" FontWeight="SemiBold"/>
          <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" MinHeight="44"/>
        </StackPanel>
        <StackPanel Spacing="6" Grid.Column="1" Margin="8,0,0,0">
          <TextBlock Text="{DynamicResource Accountant.Transactions.Filter.Status}" FontSize="12" Opacity="0.6" FontWeight="SemiBold"/>
          <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatusItem}" MinHeight="44" MinWidth="120">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
      </Grid>

      <Button Content="{Binding ToggleViewText}" Command="{Binding ToggleViewCommand}" MinHeight="40"/>

      <ItemsControl ItemsSource="{Binding FilteredTransactions}" Margin="0,8,0,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="repos:AccountantTransactionDTO">
            <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Color.Border}" BorderThickness="1">
              <Grid RowDefinitions="Auto,Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:dd.MM.yy HH:mm}'}" FontSize="11" Opacity="0.6"/>
                </Grid>
                <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="11" FontFamily="Monospace" Opacity="0.7" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                  <Border Background="{Binding State, Converter={StaticResource StatusToBrushConverter}}"
                          Padding="6,2" CornerRadius="4" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding State, Converter={StaticResource StatusToTextConverter}}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                  </Border>
                  <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding Amount, StringFormat='{}{0:F12}'}" FontFamily="Monospace" FontWeight="Bold" FontSize="13"/>
                    <TextBlock Text="{DynamicResource App.Currency}" FontSize="9" Opacity="0.5" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
