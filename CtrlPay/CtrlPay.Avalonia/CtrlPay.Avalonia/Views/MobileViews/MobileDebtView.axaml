<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             xmlns:hc="using:CtrlPay.Avalonia.HelperClasses"
             x:DataType="vm:DebtViewModel"
             x:Class="CtrlPay.Avalonia.Views.MobileViews.MobileDebtView"
             Background="{DynamicResource Color.Background}">
  <ScrollViewer>
    <StackPanel Margin="12" Spacing="12">
      <TextBox Watermark="{DynamicResource DebtView.Watermark.SearchBar}" MinHeight="44" Text="{Binding SearchTerm}"/>
      <CheckBox Content="{DynamicResource DebtView.Payable}" IsChecked="{Binding PayableChecked}"/>
      <Border BorderBrush="{DynamicResource Color.Border}" BorderThickness="1" Padding="10" CornerRadius="6">
        <StackPanel Spacing="8">
          <TextBlock Text="{DynamicResource DebtView.Sorting}" FontWeight="Bold" FontSize="13" Opacity="0.6"/>
          <ListBox Background="Transparent" BorderThickness="0" SelectedItem="{Binding SelectedSortOrder}"
                   ItemsSource="{Binding SortOptions}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="hc:SortOption">
                <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <ItemsControl ItemsSource="{Binding Debts}" Margin="0,8,0,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="hc:TransactionItem">
            <Border Classes="customerCard" Margin="0,0,0,8" CornerRadius="10">
              <Expander Classes="customerExpander" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                <Expander.Header>
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Classes="indicator" Tag="{Binding Status}" CornerRadius="2"
                            Height="18" Width="4" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource Color.Text.Primary}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Amount, StringFormat=\{0:N12\}}" FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{DynamicResource App.Currency}" Margin="6,0,0,0" VerticalAlignment="Bottom" Opacity="0.7" FontSize="11"/>
                    </StackPanel>
                  </Grid>
                </Expander.Header>
                <Border Padding="12" BorderBrush="{DynamicResource Color.Border}" BorderThickness="0,1,0,0">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Content="{DynamicResource DebtView.PayFromCredit}" Command="{Binding PayFromCreditCommand}" MinHeight="40" Padding="12,6"/>
                      <TextBlock Text="{Binding CreditPayString}" VerticalAlignment="Center" FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource DebtView.GenerateAddress}" Command="{Binding GenerateAddressCommand}" MinHeight="40" Padding="12,6"/>
                  </Grid>
                </Border>
              </Expander>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
