<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             xmlns:entities="using:CtrlPay.Entities"
             xmlns:frontend="using:CtrlPay.Repos.Frontend"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Background="{DynamicResource Color.Background}"
             x:Class="CtrlPay.Avalonia.AdminView"
             x:DataType="vm:AdminViewModel">
    
    <Grid RowDefinitions="Auto, *">
        <TextBlock Grid.Row="0" 
                   Text="Administration" 
                   Classes="h1" 
                   Margin="20,20,20,10"/>
        
        <StackPanel Grid.Row="1" Margin="20" Spacing="20">
            <Border Classes="customerCard" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="System Users" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="Manage employees and their system roles." 
                               Foreground="{DynamicResource Color.Text.Secondary}"
                               Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding SystemUsers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="frontend:FrontendUserDTO">
                                <Border BorderBrush="{DynamicResource Color.Border}" 
                                        BorderThickness="0,0,0,1" 
                                        Padding="5,10">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Username}" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Role}" FontSize="12" 
                                                       Foreground="{Binding RoleColor}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Edit" Classes="secondary"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Add New User" 
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Classes="customerCard" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="System Audit" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="View recent system activities and security logs." 
                               Foreground="{DynamicResource Color.Text.Secondary}"
                               TextWrapping="Wrap"/>
                    <Button Content="View Logs" 
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
