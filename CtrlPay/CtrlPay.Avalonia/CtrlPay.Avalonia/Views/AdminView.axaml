<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             xmlns:entities="using:CtrlPay.Entities"
             xmlns:frontend="using:CtrlPay.Repos.Frontend"
             xmlns:avalonia="using:CtrlPay.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1250" d:DesignHeight="720"
             Background="{DynamicResource Color.Background}"
             x:Class="CtrlPay.Avalonia.AdminView"
             x:DataType="vm:AdminViewModel">
    
    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource AdminView.Title}" 
                   Classes="h1" 
                   Margin="20,20,20,10"/>
        
        <!-- Filters & Search -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" Margin="20,0,20,15">
            <TextBox Grid.Column="0" 
                     Text="{Binding SearchText}" 
                     Watermark="{DynamicResource AdminView.SearchWatermark}"
                     Margin="0,0,10,0"/>

            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRoleItem}"
                      Width="150"
                      Margin="0,0,10,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Grid.Column="2" 
                    Command="{Binding AddUserCommand}"
                    Padding="15,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="+" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource AdminView.Button.AddUser}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" Margin="20,0,20,20">
            <Border Classes="customerCard" Padding="15">
                <StackPanel Spacing="5">
                    <TextBlock Text="{DynamicResource AdminView.UsersList.Title}" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding SystemUsers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:UserPieceViewModel">
                                <avalonia:UserPiece/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
