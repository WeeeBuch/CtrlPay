<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             xmlns:entities="using:CtrlPay.Entities"
             xmlns:frontend="using:CtrlPay.Repos.Frontend"
             mc:Ignorable="d" d:DesignWidth="1250" d:DesignHeight="720"
             Background="{DynamicResource Color.Background}"
             x:Class="CtrlPay.Avalonia.AdminView"
             x:DataType="vm:AdminViewModel">
    
    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Administration" 
                   Classes="h1" 
                   Margin="20,20,20,10"/>
        
        <!-- Filters & Search -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" Margin="20,0,20,15">
            <TextBox Grid.Column="0" 
                     Text="{Binding SearchText}" 
                     Watermark="Search users..."
                     Margin="0,0,10,0"/>

            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole}"
                      Width="150"
                      Margin="0,0,10,0"/>

            <Button Grid.Column="2" 
                    Padding="15,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="+" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Add User" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" Margin="20,0,20,20">
            <Border Classes="customerCard" Padding="15">
                <StackPanel Spacing="5">
                    <TextBlock Text="System Users" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding SystemUsers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="frontend:FrontendUserDTO">
                                <Border BorderBrush="{DynamicResource Color.Border}" 
                                        BorderThickness="0,0,0,1" 
                                        Padding="5,12">
                                    <Grid ColumnDefinitions="*, Auto, Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Username}" FontWeight="Medium" FontSize="15"/>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Role}" FontSize="12" 
                                                           Foreground="{Binding RoleColor}"/>
                                                <TextBlock Text="•" FontSize="12" Foreground="{DynamicResource Color.Text.Secondary}" IsVisible="{Binding TwoFactorEnabled}"/>
                                                <TextBlock Text="2FA Enabled" FontSize="12" 
                                                           Foreground="#44AAFF" 
                                                           IsVisible="{Binding TwoFactorEnabled}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Content="Reset 2FA" 
                                                Classes="secondary" 
                                                IsVisible="{Binding TwoFactorEnabled}"
                                                Margin="0,0,10,0"/>
                                                
                                        <Button Grid.Column="2" Content="Edit" Classes="secondary"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
