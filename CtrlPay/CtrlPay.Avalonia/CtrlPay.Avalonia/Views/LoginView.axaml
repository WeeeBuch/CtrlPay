<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="500"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             x:DataType="vm:LoginViewModel"
             x:Class="CtrlPay.Avalonia.LoginView"
             Background="{DynamicResource Color.Background}">
  
     <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">
        <!-- Přepínací panel Přihlásit / Registrovat -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                    Margin="0,20,0,0" Spacing="20" Grid.Row="0">
            <Button Content="{DynamicResource LoginView.Button.Switch.Login}" Width="125" 
                    Command="{Binding ToggleLoginCommand}" IsEnabled="{Binding !IsBusy}"/>
            <Button Content="{DynamicResource LoginView.Button.Switch.Register}" Width="125" 
                    Command="{Binding ToggleRegisterCommand}" IsEnabled="{Binding !IsBusy}"/>
        </StackPanel>

        <!-- Obsah formuláře -->
        <Border Grid.Row="1" CornerRadius="10" Background="#FF2A2A2A" 
                Padding="20" Margin="0,20" Width="300" MaxHeight="300">
            <StackPanel x:Name="FormPanel" Spacing="15">
                <!-- Login Fields -->
                <StackPanel x:Name="LoginForm" Spacing="10" IsVisible="{Binding IsLoginSelected}">
                    <TextBox Name="UsernameTextBox" Text="{Binding Username, Mode=TwoWay}"
                             IsEnabled="{Binding !IsBusy}"
                             Watermark="{DynamicResource LoginView.Watermark.Username}">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" 
                                        Command="{Binding LoginCommand}" />
                        </TextBox.KeyBindings>                    
                    </TextBox>
                    <TextBox Name="PasswordTextBox" Text="{Binding Password, Mode=TwoWay}"
                             IsEnabled="{Binding !IsBusy}"
                             Watermark="{DynamicResource LoginView.Watermark.Password}" PasswordChar="#">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" 
                                        Command="{Binding LoginCommand}" />
                        </TextBox.KeyBindings>                    
                    </TextBox>
                    <Button Name="LoginButton" Content="{DynamicResource LoginView.Button.Login}"
                            IsEnabled="{Binding !IsBusy}"
                            FontWeight="Bold" Command="{Binding LoginCommand}"/>
                </StackPanel>

                <!-- Register Fields (skryté) -->
                <StackPanel x:Name="RegisterForm" Spacing="10" 
                            IsVisible="{Binding !IsLoginSelected}">
                    <TextBox Name="RegUsernameTextBox" Text="{Binding RegUsername, Mode=TwoWay}"
                             IsEnabled="{Binding !IsBusy}"
                             Watermark="{DynamicResource LoginView.Watermark.Username}" >
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" 
                                        Command="{Binding RegisterCommand}" />
                        </TextBox.KeyBindings>                    
                    </TextBox>
                    <TextBox Name="RegCodeTextBox" Text="{Binding RegCode, Mode=TwoWay}"
                             IsEnabled="{Binding !IsBusy}"
                             Watermark="{DynamicResource LoginView.Watermark.Code}" >
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" 
                                        Command="{Binding RegisterCommand}" />
                        </TextBox.KeyBindings>                    
                    </TextBox>
                    <TextBox Name="RegPasswordTextBox" Text="{Binding RegPassword, Mode=TwoWay}"
                             IsEnabled="{Binding !IsBusy}"
                             Watermark="{DynamicResource LoginView.Watermark.Password}" PasswordChar="#">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" 
                                        Command="{Binding RegisterCommand}" />
                        </TextBox.KeyBindings>                    
                    </TextBox>
                    <TextBox Name="RegConfirmPasswordTextBox" Text="{Binding RegConfirmPassword, Mode=TwoWay}"
                             IsEnabled="{Binding !IsBusy}"
                             Watermark="{DynamicResource LoginView.Watermark.ConfirmPassword}" PasswordChar="#">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" 
                                        Command="{Binding RegisterCommand}" />
                        </TextBox.KeyBindings>                    
                    </TextBox>
                    <Button Name="RegisterButton" Content="{DynamicResource LoginView.Button.Register}"
                            IsEnabled="{Binding !IsBusy}"
                            FontWeight="Bold" Command="{Binding RegisterCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" 
                         MaxWidth="200" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding Message}" 
                       Foreground="{DynamicResource Brush.Error}" 
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Spacing="5" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                <TextBlock Text="API:" FontSize="10" VerticalAlignment="Center" Opacity="0.6"/>
                <TextBlock Text="{Binding ApiUrl}" FontSize="10" VerticalAlignment="Center" Opacity="0.8"
                           FontWeight="SemiBold"/>
                <Button Command="{Binding OpenApiSettingsCommand}" Padding="5,2" 
                        Background="Transparent" BorderThickness="0"
                        IsEnabled="{Binding !IsBusy}">
                    <TextBlock Text="✎" FontSize="12" Foreground="{DynamicResource Brush.Accent}"/>
                </Button>
            </StackPanel>
            <TextBlock Text="{DynamicResource App.Watermark}" FontSize="10" 
                       HorizontalAlignment="Center" Opacity="0.5"/>
        </StackPanel>
    </Grid>
</UserControl>
