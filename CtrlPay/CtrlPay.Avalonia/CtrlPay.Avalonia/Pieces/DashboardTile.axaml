<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="150"
             x:Class="CtrlPay.Avalonia.Pieces.DashboardTile"
             x:DataType="vm:DashboardTileViewModel"
             ClipToBounds="False">

    <Button Classes="plain" Command="{Binding ClickCommand}" 
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
            Padding="0" ClipToBounds="False">
        <Button.Styles>
            <Style Selector="Button.plain">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <!-- Přidáme výchozí margin, aby měla karta 'rezervu' nahoře -->
                <Setter Property="Margin" Value="0,5,0,0"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <!-- Přidáno Name="PART_ContentPresenter" -->
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Background="{TemplateBinding Background}"
                                          Content="{TemplateBinding Content}"
                                          Padding="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter>
            </Style>

            <!-- Totální vynucení průhlednosti při najetí myší -->
            <Style Selector="Button.plain:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="Button.plain:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!-- Náš vlastní vizuální efekt - stín a posun -->
            <Style Selector="Button.plain:pointerover Border#MainBorder">
                <Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
                <Setter Property="Margin" Value="0, -2, 0, 2"/>
            </Style>
        </Button.Styles>

        <Border Name="MainBorder" 
                Background="{DynamicResource Brush.Surface}" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="1" 
                CornerRadius="15" 
                Padding="20">
            
            <Border.Transitions>
                <Transitions>
                    <ThicknessTransition Property="Margin" Duration="0:0:0.2" Easing="CircularEaseOut"/>
                </Transitions>
            </Border.Transitions>

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto, *">
                    <Border Background="{Binding Color}" Width="32" Height="32" CornerRadius="8" Opacity="0.2"/>
                    <PathIcon Data="{Binding Icon}" Foreground="{Binding Color}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    
                    <TextBlock Grid.Column="1" Text="{Binding Title}" 
                               Foreground="{DynamicResource Brush.Text.Secondary}" 
                               FontSize="11" FontWeight="Bold" 
                               HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>

                <StackPanel Margin="0,5,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Amount, StringFormat=\{0:N4\}}" 
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                        <TextBlock Text="XMR" FontSize="12" Opacity="0.5" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Count}" FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                        <TextBlock Text="{DynamicResource Accountant.Dashboard.ItemsToProcess}" FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Button>
</UserControl>
