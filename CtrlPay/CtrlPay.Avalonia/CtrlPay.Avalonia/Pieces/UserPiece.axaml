<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CtrlPay.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800"
             x:Class="CtrlPay.Avalonia.UserPiece"
             x:DataType="vm:UserPieceViewModel">

    <Border BorderBrush="{DynamicResource Color.Border}" 
            BorderThickness="0,0,0,1" 
            Padding="5,12">
        <Grid ColumnDefinitions="*, Auto">
            <!-- Normal View -->
            <StackPanel Grid.Column="0" IsVisible="{Binding !Editing}" VerticalAlignment="Center">
                <TextBlock Text="{Binding Model.Username}" FontWeight="Medium" FontSize="15"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding Model.Role}" FontSize="12" 
                               Foreground="{Binding Model.RoleColor}"/>
                    
                    <!-- Ukážeme jméno zákazníka, pokud to je Customer -->
                    <TextBlock Text="{Binding CustomerDisplayName}" 
                               FontSize="12" Foreground="#888888"
                               IsVisible="{Binding ShowCustomerSelection}"/>

                    <TextBlock Text="{DynamicResource UserPiece.Label.TwoFactorEnabled}" FontSize="12" 
                               Foreground="#44AAFF" 
                               IsVisible="{Binding Model.TwoFactorEnabled}"/>
                </StackPanel>
            </StackPanel>

            <!-- Edit View -->
            <StackPanel Grid.Column="0" IsVisible="{Binding Editing}" Spacing="10" Margin="0,0,20,0">
                <!-- Username a Heslo -->
                <Grid ColumnDefinitions="*, *">
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="{DynamicResource UserPiece.Label.Username}" FontSize="11" Foreground="#888888"/>
                        <TextBox Text="{Binding Model.Username}" Watermark="{DynamicResource UserPiece.Watermark.Username}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="{DynamicResource UserPiece.Label.Password}" FontSize="11" Foreground="#888888"/>
                        <TextBox Text="{Binding Model.Password}" PasswordChar="*" Watermark="{DynamicResource UserPiece.Watermark.Password}"/>
                    </StackPanel>
                </Grid>

                <!-- Role, Zákazník a Account ID -->
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="{DynamicResource UserPiece.Label.Role}" FontSize="11" Foreground="#888888"/>
                        <ComboBox ItemsSource="{Binding RolesList}" SelectedItem="{Binding Model.Role}" 
                                  SelectionChanged="OnRoleSelectionChanged" Width="130"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,5,0" IsVisible="{Binding ShowCustomerSelection}">
                        <TextBlock Text="{DynamicResource UserPiece.Label.Customer}" FontSize="11" Foreground="#888888"/>
                        <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" 
                                  PlaceholderText="{DynamicResource UserPiece.Placeholder.Customer}" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                        <TextBlock Text="{DynamicResource UserPiece.Label.AccountId}" FontSize="11" Foreground="#888888"/>
                        <TextBox Text="{Binding Model.AccountId}" IsReadOnly="True" Width="110"/>
                    </StackPanel>
                </Grid>

                <!-- 2FA a Recovery Codes -->
                <StackPanel Spacing="5">
                    <CheckBox IsChecked="{Binding Model.TwoFactorEnabled}" Content="{DynamicResource UserPiece.Label.TwoFactorEnable}"/>
                    
                    <TextBlock Text="{DynamicResource UserPiece.Label.RecoveryCodes}" FontSize="11" Foreground="#888888"/>
                    <TextBox Text="{Binding RecoveryCodesText}" 
                             AcceptsReturn="True" Height="80" 
                             Watermark="{DynamicResource UserPiece.Watermark.RecoveryCodes}" 
                             FontSize="12" IsReadOnly="True"/>
                </StackPanel>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Top" Margin="0,5,0,0">
                <Button Content="{DynamicResource UserPiece.Button.Edit}" Command="{Binding StartEditCommand}" 
                        IsVisible="{Binding !Editing}" Classes="secondary"/>
                <Button Content="{DynamicResource UserPiece.Button.Delete}" Command="{Binding DeleteCommand}" 
                        IsVisible="{Binding !Editing}" Classes="secondary"/>
                
                <Button Content="{DynamicResource UserPiece.Button.Cancel}" Command="{Binding CancelEditCommand}" 
                        IsVisible="{Binding Editing}" Classes="secondary"/>
                <Button Content="{DynamicResource UserPiece.Button.Save}" Command="{Binding SaveCommand}" 
                        IsVisible="{Binding Editing}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
